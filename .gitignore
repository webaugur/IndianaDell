# Failed/incomplete downloads
*.crdownload
FactoryDocs/_incoming/

# Nested git clones (re-fetch with scripts)
hackrf/repos/

# Generated / copy-to-sdcard payloads
hackrf/sd-card/
hackrf/releases/*.zip

# Rebuild log (local only)
scripts/rebuild/last-run.log

# EFI timing reports (local baselines)
*.timing
B1GMB42.timing

# PERC IT flash bundle (Fohdeesha) — local cache only
.cache/perc-crossflash/
FactoryDocs/_incoming/perc-crossflash*.zip
# patched FreeDOS ISO is deployed to Wiggly only, not committed

# Generated trifold PDFs — build with bin/build-trifold-slick
B1GMB42-*-trifold.pdf
B1GMB42-trifold-slick.pdf
docs/sales/*.pdf

# Editor / session
.grok/
**/.DS_Store

# Secrets — live on Ventoy persistence / home only, never in repo
**/.ssh/id_rsa
**/.ssh/id_ed25519
**/.ssh/*.pem
**/auth.json
**/.config/gh/hosts.yml
**/.config/gh/config.yml

# Library Radio — Drive folder IDs / maps stay local only
**/LibraryRadio/folders.tsv
**/LibraryRadio/ham-radio-id-map.tsv
**/library-radio-folders.tsv
**/ham-radio-id-map.tsv
**/LibraryRadio/quarantine/
**/LibraryRadio/missing.tsv
**/LibraryRadio/holding/
**/LibraryRadio/sync-errors.log
**/LibraryRadio/MISSING*.txt
**/LibraryRadio/quarantine/

# Plymouth preview staging (local only; rebuild with --stage-only)
Themes/boot/staging/**
!Themes/boot/staging/README.md

# Plymouth generated frames (rebuild: python3 Themes/scripts/generate-dell-animation.py)
Themes/boot/generated/**
!Themes/boot/generated/README.md

# Python cache
Themes/scripts/__pycache__/
**/__pycache__/
