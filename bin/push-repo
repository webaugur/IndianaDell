#!/usr/bin/env bash
# Push IndianaDell to GitHub (webaugur/IndianaDell).
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=../scripts/github/remote.sh
source "$REPO_DIR/scripts/github/remote.sh"

cd "$REPO_DIR"

if [[ -r "$HOME/bin/resolve-secrets.sh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/bin/resolve-secrets.sh"
  materialize_secrets_to_runtime_home quiet
elif [[ -r "$REPO_DIR/scripts/ventoy/resolve-secrets.sh" ]]; then
  # shellcheck source=/dev/null
  source "$REPO_DIR/scripts/ventoy/resolve-secrets.sh"
  materialize_secrets_to_runtime_home quiet
fi

if ! command -v git >/dev/null; then
  echo "error: git is required" >&2
  exit 1
fi

if [[ ! -d .git ]]; then
  echo "error: $REPO_DIR is not a git repository" >&2
  exit 1
fi

indianadell_ensure_origin "$REPO_DIR"

if indianadell_remote_needs_gh; then
  if ! command -v gh >/dev/null; then
    echo "HTTPS remote requires GitHub CLI. Install gh or set:" >&2
    echo "  INDIANADELL_REMOTE=git@github.com:webaugur/IndianaDell.git" >&2
    exit 1
  fi
  if ! gh auth status >/dev/null 2>&1; then
    echo "GitHub CLI is not authenticated."
    echo "Run:  gh auth login"
    echo "Or use SSH:  INDIANADELL_REMOTE=git@github.com:webaugur/IndianaDell.git bin/push-repo"
    exit 1
  fi
  gh auth setup-git >/dev/null 2>&1 || true
fi

GIT_SSH_COMMAND="${GIT_SSH_COMMAND:-ssh -o BatchMode=yes -o StrictHostKeyChecking=accept-new}"
export GIT_SSH_COMMAND

echo "Pushing ${INDIANADELL_BRANCH} to ${INDIANADELL_REMOTE} ..."
git push -u origin "${INDIANADELL_BRANCH}"
echo "Done: ${INDIANADELL_WEB_URL}"