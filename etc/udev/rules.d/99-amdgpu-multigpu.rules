# Tag amdgpu GPUs for reference (unpinned — no forced primary).
SUBSYSTEM=="drm", KERNEL=="card1", ATTR{device/vendor}=="0x1002", TAG+="amdgpu_gpu_w5000"
SUBSYSTEM=="drm", KERNEL=="card2", ATTR{device/vendor}=="0x1002", TAG+="amdgpu_gpu_w5100"
SUBSYSTEM=="drm", KERNEL=="card3", ATTR{device/vendor}=="0x1002", TAG+="amdgpu_gpu_w5000"

# Desktop workstation: max DPM clocks on every amdgpu card (not just the display GPU).
# Helper is installed by etc/apply.sh → /usr/local/sbin/indiana-amdgpu-dpm-performance
ACTION=="add", SUBSYSTEM=="drm", KERNEL=="card[0-9]*", TEST=="/sys/class/drm/%k/device/power_dpm_force_performance_level", RUN+="/usr/local/sbin/indiana-amdgpu-dpm-performance"
